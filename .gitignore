# ==============================================================================
# Neve AI – .gitignore
# Tudo aqui é recriado pelo instalar.bat ou é dado de runtime.
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# Dependências & ambientes virtuais (npm install / pip install via instalar.bat)
# ──────────────────────────────────────────────────────────────────────────────
node_modules/
backend/open_webui/venv/

# ──────────────────────────────────────────────────────────────────────────────
# Build & artefatos de compilação (npm run build / SvelteKit)
# ──────────────────────────────────────────────────────────────────────────────
build/
.svelte-kit/
backend/open_webui/frontend/
backend/open_webui/static/

# ──────────────────────────────────────────────────────────────────────────────
# Modelos e binários pesados (baixados pelo usuário / instalar.bat)
# ──────────────────────────────────────────────────────────────────────────────
models/
mmproj/
llamacpp-server/bin/
*.gguf

# ──────────────────────────────────────────────────────────────────────────────
# Dados de runtime (banco, uploads, cache, vector DB)
# ──────────────────────────────────────────────────────────────────────────────
backend/data/

# ──────────────────────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────────────────────
logs/
backend/server_err.txt

# ──────────────────────────────────────────────────────────────────────────────
# Variáveis de ambiente e segredos
# ──────────────────────────────────────────────────────────────────────────────
.env
.env.*

# ──────────────────────────────────────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/

# ──────────────────────────────────────────────────────────────────────────────
# Arquivos temporários e de build
# ──────────────────────────────────────────────────────────────────────────────
build_log.txt
temp_body.json
*.log
*.tmp
*.swp
*.swo
*~

# ──────────────────────────────────────────────────────────────────────────────
# OS / IDE
# ──────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
